# ─── Required ────────────────────────────────────────────────────
PRIVATE_KEY=your_base58_private_key_here
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ─── Strategy — v3.0 Low-Liq Capital Scaling ─────────────────────
# Increased daily trade cap (10 vs 3) — more small trades compound faster
MAX_DAILY_TRADES=10

# Per-route profit targets are set in the route config (arb-bot.ts)
# Stable:     $0.20 min  |  70% of balance  |  50 bps slippage
# Volatile:   $0.10 min  |  10-20% balance  |  100-200 bps slippage
# Triangular: $0.20 min  |  10-12% balance  |  150-200 bps slippage

# Risk controls
MAX_DAILY_LOSS_PCT=5      # halt if day loss exceeds 5% of balance
PRIORITY_FEE_LAMPORTS=10000

# Safety: DRY_RUN=true simulates without executing real trades
# Change to false when ready to go live
DRY_RUN=true
