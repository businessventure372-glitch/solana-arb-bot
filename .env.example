# === SOL Micro Scalper Config ===

# Your dedicated trading wallet private key (bs58 encoded)
# NEVER use your main wallet. Export a fresh keypair from Phantom.
PRIVATE_KEY=your_bs58_private_key_here

# RPC endpoint (private recommended for speed)
# Free: https://api.mainnet-beta.solana.com (slow, rate-limited)
# Paid: QuickNode, Triton, Helius (~$10-50/mo)
RPC_URL=https://api.mainnet-beta.solana.com

# Trading parameters
TRADE_PAIR=SOL/USDC
BUY_DIP_PERCENT=0.3
TAKE_PROFIT_PERCENT=0.8
STOP_LOSS_PERCENT=2.0
MAX_POSITION_SIZE_PERCENT=30
MAX_DAILY_LOSS_PERCENT=5
SLIPPAGE_BPS=50
PRIORITY_FEE_LAMPORTS=10000
